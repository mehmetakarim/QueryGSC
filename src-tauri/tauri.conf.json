{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QueryGSC",
  "version": "0.2.0",
  "identifier": "com.mehmetakar.querygsc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QueryGSC",
        "width": 1280,
        "height": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50Y2VzdGVkIGNvbW1lbnQ6IG1pYmlzaWduIHB1YmxpYyBrZXkAcW1sazduIHB1YmlzaWduIHB1YmxpYyBrZXk6IEUxRUIxNzVGN0RFTzc3QzQKUldURWQ1TjlYeGZyNGI5M0c0NUrNUXlMXJ3NY4MWpWQ1NTTTEhkUCt4MTRBazdaYUNOKditMM1FUUEsK",
      "endpoints": [
        "https://github.com/mehmetakarim/QueryGSC/releases/latest/download/latest-{{target}}-{{arch}}.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
